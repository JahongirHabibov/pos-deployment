# Environment Variables Template
# Copy to .env and adjust values

# PostgreSQL Configuration
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=pos_secure_password_change_me
POSTGRES_DB=pos_db
POSTGRES_SERVER=pos-database
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=pos-redis
REDIS_PORT=6379
# Placeholder — replaced by provision.py on first deployment
REDIS_PASSWORD=Abcd1234!!
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-different-refresh-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Public Entrypoint
# Port exposed by the frontend container on the host machine.
POS_PUBLIC_PORT=80

# Application Settings
APP_NAME="POS System"
APP_ENV=production
DEBUG=false
ENABLE_API_DOCS=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# IANA Timezone — alle Services nutzen diesen Wert.
# Eigenen Standort eintragen: timedatectl list-timezones
TZ=Europe/Berlin

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Health Check Settings
HEALTH_CHECK_TIMEOUT=5

# Graceful Shutdown
SHUTDOWN_TIMEOUT=10

# =============================================================================
# Admin User Configuration (Initial Setup)
# =============================================================================
# These credentials are used to create the initial admin user on first startup.
# IMPORTANT: Change these values in production!
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@pos.system
ADMIN_PASSWORD=000000 # wird bald gelöscht! DEFAULT LASEN !
ADMIN_PIN=000000

# =============================================================================
# Production Deployment (docker-compose.prod.yml only)
# =============================================================================
# Container images pulled from GHCR — set exact tag per release (e.g. 0.1.0)
IMAGE_BACKEND=ghcr.io/<org>/pos-backend:0.1.0
IMAGE_FRONTEND=ghcr.io/<org>/pos-frontend:0.1.0
IMAGE_IMAGE_SERVICE=ghcr.io/<org>/pos-image-service:0.1.0
IMAGE_UPDATER=ghcr.io/<org>/pos-updater:0.1.0
IMAGE_BACKUP=ghcr.io/<org>/pos-backup:latest

# =============================================================================
# Updater Sidecar
# =============================================================================
# Docker Compose Projektname (muss mit dem laufenden Stack übereinstimmen)
COMPOSE_PROJECT_NAME=point-of-sale-prod

# Öffentliches Deployment-Repo für Release Notes (GitHub Releases API, kein Token nötig)
# Format: <owner>/<repo>
DEPLOYMENT_REPO=<org>/pos-deployment

# Absolute path to the deployment directory ON THE HOST (not the container path).
# Required for Phase 7 updater self-update and for bind-mounts in
# docker-compose.prod.yml that use ${HOST_COMPOSE_PROJECT_DIR}.
# Example: /root/pos-deployment
# HOST_COMPOSE_PROJECT_DIR=

# DRY_RUN: Set to "true" to simulate upgrades without executing real Docker commands.
# Useful for testing the upgrade flow locally without a real production environment.
# DRY_RUN=false

# DRY_RUN_NEXT_VERSION: Only used when DRY_RUN=true.
# Controls which version the mock update check returns as "latest available".
# DRY_RUN_NEXT_VERSION=

# Image cleanup grace period in seconds after a successful upgrade.
# Old images are kept for this long to allow rollback without internet access.
# Default: 86400 (24 hours)
# CLEANUP_DELAY=86400

# How often the background cleanup loop checks for pending cleanups (seconds).
# Default: 3600 (1 hour)
# CLEANUP_CHECK_INTERVAL=3600

# Filter prefix for orphan image scan — only images matching this pattern are touched.
# Never affects images from other projects on the same Docker host.
# Default: pos-
# POS_IMAGE_FILTER=pos-

# =============================================================================
# Backup Sidecar (pos-backup, Port 8300)
# =============================================================================

# Web-UI Basic Auth (Pflicht — sonst gibt der Container HTTP 503)
BACKUP_UI_USER=admin
BACKUP_UI_PASSWORD=<starkes_passwort_wählen>

# Remote-Ziel SFTP (optional)
# BACKUP_SFTP_HOST=mein-nas.example.com
# BACKUP_SFTP_PORT=22
# BACKUP_SFTP_USER=backup
# BACKUP_SFTP_PASSWORD=geheimwort
# BACKUP_SFTP_PATH=/mnt/backups/pos

# Remote-Ziel S3 (optional)
# BACKUP_S3_ENDPOINT=https://s3.example.com
# BACKUP_S3_BUCKET=pos-backups
# BACKUP_S3_ACCESS_KEY=...
# BACKUP_S3_SECRET_KEY=...
# BACKUP_S3_PREFIX=pos-backups

